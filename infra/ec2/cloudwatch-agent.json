{
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/ff-train/*.log",
            "log_group_name": "/ff/training",
            "log_stream_name": "{instance_id}/{file_basename}",
            "retention_in_days": 7,
            "timezone": "UTC"
          },
          {
            "file_path": "/var/log/cloud-init-output.log",
            "log_group_name": "/ff/training",
            "log_stream_name": "{instance_id}/cloud-init",
            "retention_in_days": 7,
            "timezone": "UTC"
          }
        ]
      }
    }
  }
}
