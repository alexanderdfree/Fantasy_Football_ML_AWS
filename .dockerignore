# Git
.git
.gitignore
.gitattributes

# Python bytecode / build artifacts
__pycache__
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# Virtual environments
venv/
.venv/
env/

# IDE / Editor
.claude/
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docs / non-runtime
docs/
instructions/
README.md
TODO.md
*.md

# Tests
tests/
**/tests/
.pytest_cache/
.coverage
htmlcov/

# CI
.github/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Logs
*.log
logs/

# Environment / secrets
.env
.env.*
*.pem
*.key

# Analysis / scratch (not needed in production containers)
analysis_output/
analysis_*.py
benchmark.py
benchmark_*.py
tune_lgbm.py
tune_rb_gate.py
tune_*.py
conftest.py

# Training code — inference doesn't import it
batch/

# Infra (EC2 bootstrap, IAM, user-data) — never belongs in a container
infra/

# Training data — keep data/splits + data/raw (both needed for inference;
# K pipeline reconstructs kicker stats from raw weekly parquets).
# (no exclusions under data/)

# Per-position outputs — exclude figures (large PNGs), keep models/ for inference
**/outputs/figures/

# Benchmark / tuning artifacts (local scratch, not needed at runtime)
benchmark_*.json
tune_*.json
tune_*.db
*.db

# Dockerfiles themselves (don't need copies inside the image)
Dockerfile
Dockerfile.*
.dockerignore

# Local dev databases / caches
*.sqlite
*.sqlite3
