# Git
.git
.gitignore
.gitattributes

# Python bytecode / build artifacts
__pycache__
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# Virtual environments
venv/
.venv/
env/

# IDE / Editor
.claude/
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docs / non-runtime — exclude markdown by default; explicitly re-include the
# files served by the in-app Wiki tab (/api/wiki/<slug> reads paths listed in
# app.py:WIKI_DOCS). Order matters: re-includes must follow the broad *.md.
*.md
!README.md
!SETUP.md
!ATTRIBUTION.md
!TODO.md
!docs/**/*.md
!instructions/DESIGN_DOC.md
!instructions/METHOD_CONTRACTS.md
!instructions/SELF_ASSESSMENT_EVIDENCE.md
!infra/ec2/README.md
!infra/aws/README.md

# instructions/ — non-MD assets (final-project handout HTML, .docx
# self-assessment, .pdf rubric reference) don't belong in the runtime image.
instructions/*.html
instructions/*.docx
instructions/*.pdf

# Tests
tests/
**/tests/
.pytest_cache/
.coverage
htmlcov/

# CI
.github/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Logs
*.log
logs/

# Environment / secrets
.env
.env.*
*.pem
*.key

# Analysis / scratch (not needed in production containers)
analysis_output/
analysis_*.py
benchmark.py
benchmark_*.py
tune_lgbm.py
tune_rb_gate.py
tune_*.py
conftest.py

# Training code — inference doesn't import it
batch/

# Infra — only the README.md files are surfaced in the wiki (re-included
# above); the bootstrap shell scripts, IAM/JSON policies, and systemd units
# don't belong in the runtime image.
infra/**/*.sh
infra/**/*.json
infra/**/*.service
infra/**/*.timer

# Training + inference data — fetched from S3 at container startup via
# shared.model_sync.sync_data_from_s3 (keeps the image ~60 MB smaller).
data/

# Per-position outputs — models fetched from S3 at startup via
# shared.model_sync.sync_models_from_s3; figures are always local scratch.
**/outputs/models/
**/outputs/figures/

# Benchmark / tuning artifacts (local scratch, not needed at runtime)
benchmark_*.json
tune_*.json
tune_*.db
*.db

# Dockerfiles themselves (don't need copies inside the image)
Dockerfile
Dockerfile.*
.dockerignore

# Local dev databases / caches
*.sqlite
*.sqlite3
